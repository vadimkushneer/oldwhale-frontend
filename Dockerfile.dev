# Dev-only image: Vite dev server (HMR). Production / GitHub Pages still use `npm run build` / `build:gh-pages` on the host or in CI — not this Dockerfile.
FROM node:20-alpine
WORKDIR /app
RUN apk add --no-cache libc6-compat
COPY package.json package-lock.json ./
RUN npm ci
COPY . .
EXPOSE 5173
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "5173"]
